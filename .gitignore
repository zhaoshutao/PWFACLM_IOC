# Install directories
/bin/
/cfg/
/html/
/include/
/lib/
/templates/

# db/ - keep hand-written templates and substitutions, ignore generated .db files
/db/*.db

# dbd/ - keep hand-written .dbd files (auto-generated ones live in O.*/ anyway)
# /dbd/ is NOT ignored here; track all .dbd under dbd/

# Local configuration files
/configure/*.local

# iocBoot generated files
/iocBoot/*ioc*/cdCommands
/iocBoot/*ioc*/dllPath.bat
/iocBoot/*ioc*/envPaths
/iocBoot/*ioc*/relPaths.sh

# iocsh
.iocsh_history

# Build directories
O.*/

# Common files created by other tools
/QtC-*
/.vscode/
*.orig
*.log
.*.swp
.DS_Store
